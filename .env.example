# Neon PostgreSQL
DATABASE_URL=postgres://<user>:<password>@<host>/<db>?sslmode=verify-full

# API runtime
HOST=127.0.0.1
PORT=3000

# Set true if you want server startup to auto-run SQL init
AUTO_INIT_DB=true
FORCE_MEMORY_STORE=false
DB_POOL_MAX=15
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=10000

# LLM runtime
OPENAI_API_KEY=<your_openai_api_key>
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# xAI (Grok) runtime
XAI_API_KEY=<your_xai_api_key>
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast-reasoning
# Optional: a higher-quality model ID for "Grok-4.1 Quality" in UI.
XAI_MODEL_QUALITY=grok-4-1-fast-reasoning
XAI_TEMPERATURE=0.7
XAI_TIMEOUT_MS=60000
XAI_RETRY_MAX_ATTEMPTS=5

# Media storage (object storage)
# driver: local | s3
MEDIA_STORAGE_DRIVER=local
# local mode directory (optional). default: apps/web/uploads
# MEDIA_LOCAL_DIR=/absolute/path/to/uploads
# Optional absolute public base URL (for both local/s3), e.g. https://cdn.example.com
# MEDIA_PUBLIC_BASE_URL=
# Max bytes allowed for incoming data URLs before upload
MEDIA_DATA_URL_MAX_BYTES=10485760
# Cache-Control header for uploaded assets
MEDIA_CACHE_CONTROL=public, max-age=31536000, immutable

# S3 / OSS / R2 mode
# MEDIA_S3_REGION=auto
# MEDIA_S3_ENDPOINT=https://<s3-endpoint>
# MEDIA_S3_BUCKET=<bucket-name>
# MEDIA_S3_ACCESS_KEY_ID=<access-key-id>
# MEDIA_S3_SECRET_ACCESS_KEY=<secret-access-key>
# MEDIA_S3_FORCE_PATH_STYLE=true
# MEDIA_S3_ACL=public-read

# Observability
# Optional read key for GET /api/v1/observability
# OBSERVABILITY_KEY=<your_observability_key>
# Optional buffer limits
# OBS_ROUTE_MAX_SAMPLES=600
# OBS_ROUTE_MAX_KEYS=180
# OBS_CLIENT_EVENT_MAX_SAMPLES=240

# Aliyun DashScope (Bailian) image generation via OpenAI-compatible endpoint
# If you use DashScope for /api/v1/paint/generate, set these values.
DASHSCOPE_API_KEY=<your_dashscope_api_key>
OPENAI_IMAGE_API_KEY=<your_dashscope_api_key>
OPENAI_IMAGE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
OPENAI_IMAGE_TIMEOUT_MS=90000

# Cost-effective text-to-image model presets (default + 2 alternatives)
OPENAI_IMAGE_MODEL=wan2.2-t2i-flash
IMAGE_MODEL_FAST=wan2.1-t2i-turbo
IMAGE_MODEL_BALANCED=wan2.2-t2i-flash
IMAGE_MODEL_QUALITY=z-image-turbo
